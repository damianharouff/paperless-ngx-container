# Paperless-ngx environment. Copy to paperless.env (paperless.sh up does this
# automatically on first run) and edit the secret/passwords before exposing
# the service to anything you care about.

# --- Paperless app config ---------------------------------------------------
PAPERLESS_SECRET_KEY=change-me-on-first-run
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TIME_ZONE=UTC
PAPERLESS_OCR_LANGUAGE=eng

# --- Redis broker -----------------------------------------------------------
PAPERLESS_REDIS=redis://paperless-broker:6379

# --- Postgres ---------------------------------------------------------------
# These must match between the paperless container and the postgres container.
PAPERLESS_DBHOST=paperless-db
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=paperless
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=paperless

# --- Optional add-ons (only consulted when started with --with-tika /
#     --with-gotenberg). Safe to leave set even when the services aren't up;
#     paperless only contacts them if PAPERLESS_TIKA_ENABLED=1.
PAPERLESS_TIKA_ENABLED=0
PAPERLESS_TIKA_ENDPOINT=http://paperless-tika:9998
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://paperless-gotenberg:3000

# --- Tailscale sidecar (--with-tailscale) ----------------------------------
# Get a reusable auth key from https://login.tailscale.com/admin/settings/keys
# Required when using --with-tailscale. Hostname becomes the tailnet node
# name (so the URL is https://$TS_HOSTNAME.<your-tailnet>.ts.net).
TS_AUTHKEY=
TS_HOSTNAME=paperless
TS_EXTRA_ARGS=
